[Desktop Entry]
Name=Snapix
GenericName=Screenshot Editor
Comment=Screenshot beautifier for Linux
Exec=snapix
Icon=io.github.snapix.Snapix
Terminal=false
Type=Application
Categories=Graphics;2DGraphics;RasterGraphics;GTK;Utility;
Keywords=screenshot;screen capture;capture;annotate;annotation;editor;beautify;image;
StartupNotify=true
StartupWMClass=io.github.snapix.Snapix
MimeType=image/png;image/jpeg;image/webp;
